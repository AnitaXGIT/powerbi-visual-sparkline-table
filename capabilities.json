{
    "dataRoles": [
        { "displayName": "Category", "name": "category", "kind": "Grouping" },
        { "displayName": "Metric Columns", "name": "metricValues", "kind": "Measure" },
        { "displayName": "Stacked Bar Segments", "name": "stackedValues", "kind": "Measure" },
        { "displayName": "Bubble Size", "name": "bubbleValues", "kind": "Measure" },
